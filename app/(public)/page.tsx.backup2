            <div className="space-y-2 mb-3">
              {["50 leads/mes", "75 clientes activos", "30 facturas/mes"].map((t) => (
                <div key={t} className="flex items-center gap-2">
                  <span className="w-[5px] h-[5px] rounded-full bg-[#1FA97A]/40 shrink-0" />
