{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],

    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,

    "esModuleInterop": true,

    "module": "esnext",
    "moduleResolution": "bundler",

    "resolveJsonModule": true,
    "isolatedModules": true,

    "jsx": "react-jsx",
    "incremental": true,

    "baseUrl": ".",

    "paths": {
      "@/*": ["./src/*"],
      "@src/*": ["./src/*"],
      "@/modules/*": ["./modules/*"],
      "@/components/*": ["./components/*"],
      "@/app/*": ["./app/*"],
      "@/lib/*": ["./lib/*"],
      "@/config/*": ["./config/*"],
      "@/core/*": ["./core/*"],
      "@/context/*": ["./context/*"],
      "@domains/*": ["src/domains/*"],
      "@analytics/*": ["src/analytics/*"],
      "@sdk/*": ["src/sdk/*"],
      "@infra/*": ["src/infrastructure/*"],
      "@shared/*": ["src/shared/*"],
      "@platform/*": ["src/platform/*"],
      "@automation/*": ["src/automation/*"],
      "@integrations/*": ["src/integrations/*"]
    },

    "plugins": [
      {
        "name": "next"
      }
    ]
  },

  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],

  "exclude": ["node_modules", "scripts"]
}