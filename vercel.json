{
  "crons": [
    {
      "path": "/api/cron/check-automations",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/daily-tasks-email",
      "schedule": "0 20 * * *"
    }
  ],
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 10
    },
    "app/api/**/pdf/**/*.ts": {
      "maxDuration": 25
    },
    "app/api/auth/**/*.ts": {
      "maxDuration": 15
    },
    "app/api/v1/ingest/**/*.ts": {
      "maxDuration": 30
    },
    "app/api/cron/**/*.ts": {
      "maxDuration": 60
    }
  }
}
