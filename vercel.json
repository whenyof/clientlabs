{
  "crons": [
    { "path": "/api/cron/check-automations",  "schedule": "0 9 * * *"   },
    { "path": "/api/cron/daily-tasks-email",   "schedule": "0 20 * * *"  },
    { "path": "/api/cron/onboarding-emails",   "schedule": "30 9 * * *"  },
    { "path": "/api/cron/weekly-summary",      "schedule": "0 9 * * 1"   },
    { "path": "/api/cron/billing/reminders",   "schedule": "0 8 * * *"   },
    { "path": "/api/cron/recurring-invoices",  "schedule": "0 7 * * *"   },
    { "path": "/api/cron/scoring-decay",       "schedule": "0 3 * * *"   },
    { "path": "/api/cron/sync-calendar",       "schedule": "0 */6 * * *" },
    { "path": "/api/cron/send-campaigns",     "schedule": "0 * * * *"   }
  ],
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 10
    },
    "app/api/**/pdf/**/*.ts": {
      "maxDuration": 25
    },
    "app/api/auth/**/*.ts": {
      "maxDuration": 15
    },
    "app/api/v1/ingest/**/*.ts": {
      "maxDuration": 30
    },
    "app/api/cron/**/*.ts": {
      "maxDuration": 60
    }
  }
}
